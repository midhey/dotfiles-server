#!/usr/bin/env bash

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VERSION="${1:-}"

if [[ -z "$VERSION" ]]; then
  VERSION="$(git -C "$ROOT" describe --tags --abbrev=0 2>/dev/null || true)"
fi

VERSION="${VERSION#v}"

if [[ -z "$VERSION" ]]; then
  printf 'usage: scripts/package-release <version>\n' >&2
  exit 2
fi

PACKAGE_NAME="dotfiles-server-v$VERSION"
DIST_DIR="$ROOT/dist"
ARCHIVE="$DIST_DIR/$PACKAGE_NAME.tar.gz"

mkdir -p "$DIST_DIR"
rm -f "$ARCHIVE"

if git -C "$ROOT" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git -C "$ROOT" archive \
    --format=tar.gz \
    --prefix="$PACKAGE_NAME/" \
    --output="$ARCHIVE" \
    HEAD
else
  tar \
    --exclude='.git' \
    --exclude='.serena' \
    --exclude='dist' \
    -czf "$ARCHIVE" \
    -C "$ROOT/.." \
    --transform "s#^$(basename "$ROOT")#$PACKAGE_NAME#" \
    "$(basename "$ROOT")"
fi

printf '%s\n' "$ARCHIVE"

